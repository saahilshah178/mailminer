# Inbox AI environment variables
#
# Local dev: copy to `.env.local` and fill in every blank.
# Vercel:    add the same keys (without the localhost-specific URLs) in
#            Project Settings -> Environment Variables. NEXTAUTH_URL / AUTH_URL
#            are NOT required on Vercel — Auth.js v5 reads VERCEL_URL via
#            `trustHost: true` (configured in lib/auth.ts).

# ----- NextAuth / Auth.js v5 -----
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Local dev only — leave blank on Vercel.
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000

# ----- Google OAuth -----
# https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs (add BOTH):
#   http://localhost:3000/api/auth/callback/google
#   https://<your-vercel-domain>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ----- Supabase -----
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ----- Anthropic (Claude) -----
ANTHROPIC_API_KEY=

# ----- OpenAI (embeddings only) -----
OPENAI_API_KEY=

# ----- Inngest -----
# Local dev: leave INNGEST_EVENT_KEY and INNGEST_SIGNING_KEY blank, run `npx inngest-cli@latest dev`.
# Production: get from https://app.inngest.com (required on Vercel).
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ----- Encryption -----
# 32-byte hex string for AES-256-GCM. Generate with: openssl rand -hex 32
ENCRYPTION_KEY=
