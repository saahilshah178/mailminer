# ----- Inngest -----
# Local dev: leave INNGEST_EVENT_KEY and INNGEST_SIGNING_KEY blank, run `npx inngest-cli@latest dev`
# Production: get from https://app.inngest.com
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ----- Encryption -----
# 32-byte hex string for AES-256-GCM. Generate with: openssl rand -hex 32
ENCRYPTION_KEY=
